local function stopAnimation()
	if stopTimer then
		task.cancel(stopTimer)
		stopTimer = nil
	end
	if currentTrack then
		currentTrack:Stop()
	end
	isPlaying = false
	currentTrack = nil
	playBtn.Text = "Play"
	playBtn.BackgroundColor3 = Color3.fromRGB(170, 140, 255)
end

local function playAnimation()
	if isPlaying then return end
	local track = animTracks[currentIndex]
	if not track then return end
	
	local animData = allAnims[currentIndex]
	
	-- MODIFIED: Handle no-loop animations
	if animData.noLoop then
		track.Looped = false
	else
		track.Looped = true
	end
	
	track:Play()
	track:AdjustSpeed(1)
	currentTrack = track
	isPlaying = true
	playBtn.Text = "Stop"
	playBtn.BackgroundColor3 = Color3.fromRGB(255, 100, 100)

	-- MODIFIED: Force stop after duration for legit animations
	if animData and animData.duration then
		stopTimer = task.delay(animData.duration, function()
			if currentTrack == track and isPlaying then
				stopAnimation()
			end
		end)
	end
end

playBtn.MouseButton1Click:Connect(function()
	if isPlaying then
		stopAnimation()
	else
		playAnimation()
	end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == Enum.KeyCode.Q then
		if isPlaying then
			stopAnimation()
		else
			playAnimation()
		end
	end
end)

local function setupAnimations(character)
	local humanoid = character:WaitForChild("Humanoid")
	local animator = humanoid:WaitForChild("Animator")

	animTracks = {}

	for i, animData in ipairs(allAnims) do
		local anim = Instance.new("Animation")
		anim.AnimationId = animData.id

		local success, result = pcall(function()
			return animator:LoadAnimation(anim)
		end)

		if success and result then
			animTracks[i] = result

			result.Stopped:Connect(function()
				if currentTrack == result then
					stopAnimation()
				end
			end)
		else
			warn("Failed to load " .. animData.name .. ": " .. tostring(result))
		end
	end
end

