dropdownFrame.Size = UDim2.new(0, 130, 0, #animations * 29 + 4)

dropdownBtn.MouseButton1Click:Connect(function()
	dropdownOpen = not dropdownOpen
	dropdownFrame.Visible = dropdownOpen
	dropdownBtn.Text = dropdownOpen and "^" or "v"
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		if dropdownOpen then
			local pos = input.Position
			local dPos = dropdownFrame.AbsolutePosition
			local dSize = dropdownFrame.AbsoluteSize
			local bPos = dropdownBtn.AbsolutePosition
			local bSize = dropdownBtn.AbsoluteSize
			local outsideDropdown = pos.X < dPos.X or pos.X > dPos.X + dSize.X or pos.Y < dPos.Y or pos.Y > dPos.Y + dSize.Y
			local outsideButton = pos.X < bPos.X or pos.X > bPos.X + bSize.X or pos.Y < bPos.Y or pos.Y > bPos.Y + bSize.Y
			if outsideDropdown and outsideButton then
				dropdownOpen = false
				dropdownFrame.Visible = false
				dropdownBtn.Text = "v"
			end
		end
	end
end)

local function stopAnimation()
	if currentTrack then
		currentTrack:Stop()
	end
	isPlaying = false
	currentTrack = nil
	playBtn.Text = "Play Animation"
	playBtn.BackgroundColor3 = Color3.fromRGB(170, 140, 255)
end

local function playAnimation()
	local track = animTracks[currentIndex]
	if not track then return end
	track:Play()
	track:AdjustSpeed(1)
	currentTrack = track
	isPlaying = true
	playBtn.Text = "Stop Animation"
	playBtn.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
end

playBtn.MouseButton1Click:Connect(function()
	if isPlaying then
		stopAnimation()
	else
		playAnimation()
	end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == Enum.KeyCode.Q then
		if isPlaying then
			stopAnimation()
		else
			playAnimation()
		end
	end
end)

local function setupAnimations(character)
	local humanoid = character:WaitForChild("Humanoid")
	local animator = humanoid:WaitForChild("Animator")

	animTracks = {}

	for i, animData in ipairs(animations) do
		local anim = Instance.new("Animation")
		anim.AnimationId = animData.id

		local success, result = pcall(function()
			return animator:LoadAnimation(anim)
		end)

		if success and result then
			animTracks[i] = result

			result.Stopped:Connect(function()
				if currentTrack == result then
					stopAnimation()
				end
			end)
		else
			warn("Failed to load " .. animData.name .. ": " .. tostring(result))
		end
	end
end

if player.Character then
	setupAnimations(player.Character)
end

player.CharacterAdded:Connect(function(char)
	stopAnimation()
	setupAnimations(char)
end)

local draggingWindow = false
local dragStart, startPos

topBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		draggingWindow = true
		dragStart = input.Position
		startPos = mainFrame.Position
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		draggingWindow = false
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if draggingWindow and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStart
		mainFrame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)
