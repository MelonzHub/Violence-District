		createIndicator()
	else
		radiusToggle.Text = "Radius: OFF"
		radiusToggle.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
		destroyIndicator()
		cooldown = false
	end
end)

settingsBtn.MouseButton1Click:Connect(function()
	settingsOpen = not settingsOpen
	settingsFrame.Visible = settingsOpen
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		if settingsOpen then
			local pos = input.Position
			local sPos = settingsFrame.AbsolutePosition
			local sSize = settingsFrame.AbsoluteSize
			local bPos = settingsBtn.AbsolutePosition
			local bSize = settingsBtn.AbsoluteSize
			local outsideSettings = pos.X < sPos.X or pos.X > sPos.X + sSize.X or pos.Y < sPos.Y or pos.Y > sPos.Y + sSize.Y
			local outsideButton = pos.X < bPos.X or pos.X > bPos.X + bSize.X or pos.Y < bPos.Y or pos.Y > bPos.Y + bSize.Y
			if outsideSettings and outsideButton then
				settingsOpen = false
				settingsFrame.Visible = false
			end
		end
	end
end)

RunService.Heartbeat:Connect(function()
	if not radiusEnabled then return end
	if cooldown then return end

	local char = player.Character
	if not char then return end

	local hrp = char:FindFirstChild("HumanoidRootPart")
	local humanoid = char:FindFirstChild("Humanoid")
	
	if hrp and indicator then
		indicator.Position = hrp.Position - Vector3.new(0, 2.5, 0)
	end

	-- MODIFIED: Check for "Even more Legit" feature
	if evenMoreLegit and humanoid and isPlaying then
		local rootPart = humanoid.RootPart or hrp
		if rootPart then
			local currentVelocity = rootPart.AssemblyLinearVelocity.Magnitude
			if currentVelocity > 0.5 then  -- Threshold untuk mendeteksi pergerakan
				stopAnimation()
				cooldown = true
				task.delay(0.5, function()
					cooldown = false
				end)
				return
			end
		end
	end

	local nearby = getNearbyEnemy(char)
	if nearby then
		cooldown = true
		if not isPlaying then
			playAnimation()
		end
		task.wait(1)
		cooldown = false
	end
end)

player.CharacterRemoving:Connect(function()
	destroyIndicator()
	cooldown = false
end)
