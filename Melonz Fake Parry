local function hasLineOfSight(targetHRP, myHRP, myChar)
	local rayParams = RaycastParams.new()
	local filterList = {}
	for _, part in ipairs(myChar:GetDescendants()) do
		if part:IsA("BasePart") then
			table.insert(filterList, part)
		end
	end
	rayParams.FilterDescendantsInstances = filterList
	rayParams.FilterType = Enum.RaycastFilterType.Blacklist

	local direction = targetHRP.Position - myHRP.Position
	local result = Workspace:Raycast(myHRP.Position, direction, rayParams)

	if not result then return true end
	return result.Instance:IsDescendantOf(targetHRP.Parent)
end

local function isEnemy(targetPlayer)
	local myTeam = player.Team
	local theirTeam = targetPlayer.Team
	if not myTeam or not theirTeam then return true end
	return myTeam ~= theirTeam
end

local function getNearbyEnemy(myChar)
	local myHRP = myChar:FindFirstChild("HumanoidRootPart")
	if not myHRP then return nil end

	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player and p.Character then
			local targetHRP = p.Character:FindFirstChild("HumanoidRootPart")
			if targetHRP then
				local dist = (targetHRP.Position - myHRP.Position).Magnitude
				if dist <= detectionRadius then
					if not isEnemy(p) then continue end
					if hasLineOfSight(targetHRP, myHRP, myChar) then
						return p
					end
				end
			end
		end
	end
	return nil
end

